{
  "name": "civitrack-backend",
  "version": "1.0.0",
  "description": "CiviTrack Backend - Planning Approval System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:ci": "jest --ci --runInBand --coverage",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand tests/integration",
    "test:coverage": "jest --runInBand --coverage",
    "test:backend": "node test-backend-workflows.js && node audit_demo_workflow.js",
    "db:migrate": "node run_db_migrations.js",
    "audit:workflow": "node audit_demo_workflow.js",
    "seed:sample": "node setup-test-accounts.js && node seed-sample-data.js",
    "db:reset:transactional:dry-run": "node scripts/reset-transactional-data.js",
    "db:reset:transactional": "node scripts/reset-transactional-data.js --apply",
    "db:seed:realistic": "node setup-test-accounts.js && node seed-sample-data.js",
    "db:seed:realistic:bulk": "node scripts/seed-realistic-workflow-bulk.js --count=54 --newApplicants=18",
    "db:refresh:realistic": "node scripts/reset-transactional-data.js --apply && node setup-test-accounts.js && node seed-sample-data.js",
    "db:refresh:realistic:bulk": "node scripts/reset-transactional-data.js --apply && node setup-test-accounts.js && node seed-sample-data.js && node scripts/seed-realistic-workflow-bulk.js --count=54 --newApplicants=18",
    "seed:demo:fix": "node seed_demo_coverage_gaps.js",
    "docs:recover:dry-run": "node scripts/recover-document-files-from-backup.js",
    "docs:recover:apply": "node scripts/recover-document-files-from-backup.js --apply",
    "docs:generate-sample:dry-run": "node scripts/generate-missing-sample-documents.js",
    "docs:generate-sample:apply": "node scripts/generate-missing-sample-documents.js --apply",
    "docs:generate-sample:refresh:dry-run": "node scripts/generate-missing-sample-documents.js --force",
    "docs:generate-sample:refresh": "node scripts/generate-missing-sample-documents.js --apply --force"
  },
  "keywords": [
    "planning",
    "approval",
    "civitrack"
  ],
  "author": "Kelaniya Pradeshiya Sabha",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 12,
        "functions": 18,
        "lines": 25,
        "statements": 25
      }
    }
  }
}
